{
  "version": "1.0.22",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev-theme.ts",
    "build:theme": "node scripts/build-theme.ts",
    "build:pkg": "vp run --cache build --filter './packages/**'",
    "docs:dev": "pnpm -C docs run dev",
    "docs:build": "pnpm -C docs run build",
    "typecheck": "vue-tsc --noEmit",
    "release": "tsx scripts/release.ts",
    "publish-ci": "tsx scripts/publish-ci.ts",
    "test": "vp test",
    "lint": "vp lint",
    "fmt": "vp fmt",
    "check": "vp check"
  },
  "devDependencies": {
    "@clack/prompts": "catalog:",
    "@tailwindcss/typography": "catalog:",
    "@tsdown/css": "^0.21.4",
    "@types/node": "catalog:",
    "bumpp": "catalog:",
    "picocolors": "catalog:",
    "tona-vite": "workspace:*",
    "typescript": "catalog:",
    "vite-plus": "catalog:",
    "zx": "catalog:"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "packageManager": "pnpm@10.32.1"
}
